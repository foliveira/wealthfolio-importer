{
  "name": "wealthfolio-ai-importer-addon",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:server": "vite --port 3001",
    "build": "tsc && vite build && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs dist/",
    "clean": "rm -rf dist",
    "package": "zip -r ai-importer.zip manifest.json dist/ README.md",
    "bundle": "npm run clean && npm run build && npm run package"
  },
  "dependencies": {
    "pdfjs-dist": "^5.6.205"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup-plugin-external-globals": "^0.13.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
